# LLM provider keys (server-only; not exposed to the browser)
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# thirdweb — x402 facilitator + Engine Cloud server wallet
# Get these from https://thirdweb.com → Dashboard → Settings → API Keys
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=
THIRDWEB_SECRET_KEY=

# thirdweb-managed server wallet — public address only, no PK in env (thirdweb custodies it)
SERVER_WALLET_ADDRESS=

# Celo network — https://forno.celo.org for mainnet
CELO_RPC=https://forno.celo.org

# Per-query price in USDm (= cUSD = Mento Dollar = 1 USD)
PAY_PER_QUERY_USDM=0.02

# PromptReceipt contract address (set after Day 5-6 deploy on Celo mainnet)
NEXT_PUBLIC_PROMPT_RECEIPT_ADDRESS=

# Celoscan API key — for `pnpm hardhat verify` after deploy
CELOSCAN_API_KEY=
