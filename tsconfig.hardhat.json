{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "hardhat.config.ts",
    "test/contracts/**/*.ts",
    "scripts/**/*.ts"
  ],
  "exclude": ["node_modules", ".next", "artifacts", "cache"]
}
