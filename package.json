{
  "name": "pay-chat",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "hh": "cross-env TS_NODE_PROJECT=tsconfig.hardhat.json hardhat",
    "hh:compile": "pnpm hh compile",
    "hh:test": "pnpm hh test",
    "hh:deploy:celo": "pnpm hh run scripts/deploy-prompt-receipt.ts --network celo",
    "hh:deploy:sepolia": "pnpm hh run scripts/deploy-prompt-receipt.ts --network celoSepolia",
    "build:icons": "node scripts/build-icon.mjs"
  },
  "dependencies": {
    "@celo/identity": "^5.1.2",
    "@tabler/icons-react": "^3.41.1",
    "@tanstack/react-query": "^5.99.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "thirdweb": "^5.119.4",
    "viem": "^2.48.1",
    "wagmi": "^3.6.2"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@openzeppelin/contracts": "^5.6.1",
    "@tailwindcss/postcss": "^4",
    "@types/chai": "^4.3.20",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/ui": "^2.1.9",
    "chai": "^4.5.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "hardhat": "^2.28.6",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^2.1.9"
  }
}
